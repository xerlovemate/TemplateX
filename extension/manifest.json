{
  "manifest_version": 3,
  "name": "TemplateX",
  "description": "Шаблоны сообщений для менеджеров с быстрой вставкой в поля ввода.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "TemplateX"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/shared/types.js",
        "src/shared/templates.js",
        "src/shared/shortcuts.js",
        "src/shared/storage.js",
        "src/shared/payments.js",
        "src/content/editor-adapter.js",
        "src/content/overlay.js",
        "src/content/content.js"
      ],
      "css": [
        "src/content/styles.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "public/icons/templateio.svg",
        "src/content/styles.css",
        "src/content/overlay-frame.html",
        "src/content/overlay-frame.css",
        "src/content/overlay-frame.js",
        "src/shared/types.js",
        "src/shared/templates.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
